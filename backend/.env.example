# ==============================
# APP CONFIG
# ==============================
NODE_ENV=development
PORT=5000
APP_NAME=inventory-backend

# ==============================
# SQL SERVER CONFIG
# ==============================
DB_USER=testuser
DB_PASSWORD=!@#$%
DB_SERVER=localhost
DB_NAME=InventoryDB
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT=30000

# ==============================
# LOGGER CONFIG
# ==============================
LOG_LEVEL=info